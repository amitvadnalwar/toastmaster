SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
GUEST_JWT_SECRET=a-separate-random-secret-for-guest-tokens
GUEST_TOKEN_EXPIRE_HOURS=4

# SMTP email — used to send temp passwords to new members
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourclub@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=yourclub@gmail.com
