SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
GUEST_JWT_SECRET=a-separate-random-secret-for-guest-tokens
GUEST_TOKEN_EXPIRE_HOURS=4

# TLS cert verification for outbound calls. Leave unset (defaults True) in
# production. Only set to false on a local dev network that does SSL inspection
# with a cert Python doesn't trust. NEVER set this on Render.
# SSL_VERIFY=false

# SendGrid email — used to send temp passwords to new members
# Get an API key at https://app.sendgrid.com/settings/api_keys
# EMAIL_FROM_ADDRESS must exactly match a Single Sender verified at
# https://app.sendgrid.com/settings/sender_auth (no domain required)
EMAIL_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM_ADDRESS=yourclub@gmail.com
EMAIL_FROM_NAME=Toastmaster PSE

# Sentry error monitoring — https://sentry.io (optional; leave blank to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
